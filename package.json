{
  "name": "i-ching-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "debug:deps": "npm list --depth=3 | grep -E 'katex|react-katex|vite|rollup|rolldown|esbuild|babel|swc'",
    "debug:katex-version": "node -e \"console.log(require('./node_modules/katex/package.json').version)\"",
    "debug:build-inspect": "vite build && grep -o '.\\{60\\}quad.\\{60\\}' dist/assets/index-*.js || echo 'quad not found in bundle'",
    "debug:bundle-strings": "vite build --mode development && grep -o '.\\{40\\}lvert.\\{40\\}' dist/assets/index-*.js",
    "debug:lockfile": "cat package-lock.json | grep -A3 '\"katex\"' | head -30",
    "debug:full": "npm run debug:deps && npm run debug:katex-version && npm run debug:build-inspect"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "d3": "^7.9.0",
    "katex": "^0.16.45",
    "lucide-react": "^1.9.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-katex": "^3.1.0",
    "react-router-dom": "^7.14.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-katex": "^3.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^5.4.21"
  }
}
